normalize_runtime_fixture_checks() {
  local fixture_check
  local runtime_check
  local roots
  local filter
  local description

  while IFS='|' read -r fixture_check runtime_check roots filter description; do
    if has_changed_check "$runtime_check"; then
      remove_changed_check "$runtime_check"
      add_changed_check "$fixture_check"
    fi
  done < <(runtime_fixture_scopes)
}

run_runtime_fixture_scope() {
  local requested="$1"
  local fixture_check
  local runtime_check
  local roots
  local filter
  local description
  local -a root_args

  while IFS='|' read -r fixture_check runtime_check roots filter description; do
    if [[ "$requested" == "$fixture_check" ]]; then
      read -r -a root_args <<< "$roots"
      run_with_optional_fixture "$filter" "${root_args[@]}" -- cargo test -q -p xo --test jit
      return
    fi
  done < <(runtime_fixture_scopes)

  return 1
}

assert_runtime_fixture_scope_routing() {
  local fixture_check
  local runtime_check
  local roots
  local filter
  local description
  local path

  while IFS='|' read -r fixture_check runtime_check roots filter description; do
    case "$runtime_check" in
      runtime-collections) path=crates/echo_runtime/src/collections.rs ;;
      runtime-output) path=crates/echo_runtime/src/output.rs ;;
      runtime-reflection) path=crates/echo_runtime/src/reflection.rs ;;
      runtime-math) path=crates/echo_runtime/src/math.rs ;;
      runtime-encoding) path=crates/echo_runtime/src/encoding.rs ;;
      runtime-filesystem) path=crates/echo_runtime/src/filesystem.rs ;;
      runtime-time) path=crates/echo_runtime/src/time.rs ;;
      runtime-string) path=crates/echo_runtime/src/string.rs ;;
      *) continue ;;
    esac
    assert_routing "$description normalizes fixture coverage" $'runtime\njit\n'"$fixture_check" \
      crates/echo_runtime/src/lib.rs \
      "$path"
  done < <(runtime_fixture_scopes)
}

run_pipeline_checks() {
  test_crates echo_parser echo_semantics echo_hir echo_mir
}

changed_files() {
  {
    git diff --name-only --diff-filter=ACMRTD
    git diff --cached --name-only --diff-filter=ACMRTD
    git ls-files --others --exclude-standard
  } | sort -u
}

add_changed_check() {
  local check="$1"
  local existing

  for existing in "${changed_checks[@]}"; do
    [[ "$existing" == "$check" ]] && return
  done

  changed_checks+=("$check")
}

remove_changed_check() {
  local check="$1"
  local kept=()
  local existing

  for existing in "${changed_checks[@]}"; do
    [[ "$existing" == "$check" ]] && continue
    kept+=("$existing")
  done

  changed_checks=("${kept[@]}")
}

add_changed_fixture() {
  local fixture="$1"
  local existing

  for existing in "${changed_fixtures[@]}"; do
    [[ "$existing" == "$fixture" ]] && return
  done

  changed_fixtures+=("$fixture")
}

has_changed_check() {
  local check="$1"
  local existing

  for existing in "${changed_checks[@]}"; do
    [[ "$existing" == "$check" ]] && return 0
  done

  return 1
}

add_fixture_checks() {
  local path="$1"
  local root
  local fixture

  root="$(dirname "$(dirname "$path")")"
  fixture="$(basename "$(dirname "$path")")"
  if [[ "$root" != "tests/php" && "$root" != "tests/echo" ]]; then
    return 0
  fi
  [[ -z "$fixture" || "$fixture" == "." ]] && return

  add_changed_fixture "$fixture"
}

add_changed_fixture_checks() {
  local filter

  ((${#changed_fixtures[@]} > 0)) || return 0
  filter="$(IFS=','; printf '%s' "${changed_fixtures[*]}")"
  if ! has_changed_check "parser"; then
    add_changed_check "parser $filter"
  fi
  if ! has_changed_check "jit"; then
    add_changed_check "jit $filter"
  fi
  add_changed_check "fixture $filter"
}

normalize_changed_checks() {
  if has_changed_check "runtime"; then
    remove_changed_check "runtime-execution"
    normalize_runtime_fixture_checks
  fi
}

add_checks_for_changed_path() {
  local path="$1"

  case "$path" in
    AGENTS.md|scripts/check-fast)
      add_changed_check "script"
      ;;
    crates/echo_source/*)
      add_changed_check "source"
      ;;
    crates/echo_diagnostics/*)
      add_changed_check "diagnostics"
      ;;
    crates/echo_lexer/*)
      add_changed_check "lexer"
      ;;
    crates/echo_ast/*)
      add_changed_check "ast"
      add_changed_check "parser"
      ;;
    crates/echo_parser/*)
      add_changed_check "parser"
      ;;
    crates/echo_semantics/src/index_facts.rs)
      add_changed_check "semantics-index"
      ;;
    crates/echo_semantics/*)
      add_changed_check "semantics"
      ;;
    crates/echo_hir/*)
      add_changed_check "hir"
      ;;
    crates/echo_mir/src/lowering.rs)
      add_changed_check "mir-lowering"
      ;;
    crates/echo_mir/*)
      add_changed_check "mir"
      ;;
    crates/echo_codegen/src/jit.rs)
      add_changed_check "codegen-jit"
      ;;
    crates/echo_codegen/src/runtime_symbols.rs)
      add_changed_check "codegen-jit"
      ;;
    crates/echo_codegen/src/abi.rs)
      add_changed_check "codegen-abi"
      ;;
    crates/echo_codegen/src/collection_lowering.rs)
      add_changed_check "codegen-collections"
      ;;
    crates/echo_codegen/src/expression_lowering.rs)
      add_changed_check "codegen-expressions"
      ;;
    crates/echo_codegen/src/php_lowering.rs)
      add_changed_check "codegen-php"
      ;;
    crates/echo_codegen/src/std_lowering.rs)
      add_changed_check "codegen-stdlib"
      ;;
    crates/echo_codegen/src/lib.rs)
      add_changed_check "codegen-abi"
      add_changed_check "codegen-collections"
      add_changed_check "codegen-expressions"
      add_changed_check "codegen-php"
      add_changed_check "codegen-stdlib"
      ;;
    crates/echo_codegen/*)
      add_changed_check "codegen"
      add_changed_check "jit"
      ;;
    crates/echo_runtime/src/collections.rs)
      add_changed_check "runtime-collections"
      ;;
    crates/echo_runtime/src/runtime_tests/*.rs)
      if ! add_runtime_test_module_check_for_path "$path"; then
        add_changed_check "runtime-tests"
      fi
      ;;
    crates/echo_runtime/src/runtime_tests.rs)
      add_changed_check "runtime-tests"
      ;;
    crates/echo_runtime/src/assertions.rs)
      add_changed_check "runtime-assert"
      ;;
    crates/echo_runtime/src/callable.rs|crates/echo_runtime/src/error.rs)
      add_changed_check "runtime-callable"
      ;;
    crates/echo_runtime/src/task.rs)
      add_changed_check "runtime-task"
      ;;
    crates/echo_runtime/src/task_group.rs)
      add_changed_check "runtime-task-group"
      ;;
    crates/echo_runtime/src/execution.rs)
      add_changed_check "runtime-execution"
      ;;
    crates/echo_runtime/src/output.rs)
      add_changed_check "runtime-output"
      ;;
    crates/echo_runtime/src/poll.rs)
      add_changed_check "runtime-poll"
      ;;
    crates/echo_runtime/src/reflection.rs)
      add_changed_check "runtime-reflection"
      ;;
    crates/echo_runtime/src/require.rs)
      add_changed_check "runtime-require"
      ;;
