echo_commands_enabled() {
  [[ "${CHECK_FAST_ECHO_COMMANDS:-1}" != "0" ]]
}

run() {
  if echo_commands_enabled; then
    printf ':: %s\n' "$*"
  fi
  "$@"
}

replay_failure_output() {
  local output="$1"
  local max_lines="${CHECK_FAST_MAX_OUTPUT_LINES:-160}"
  local head_lines
  local line_count
  local omitted
  local tail_lines

  if [[ ! "$max_lines" =~ ^[0-9]+$ || "$max_lines" == "0" ]]; then
    cat "$output" >&2
    printf '\nfull check output retained at %s\n' "$output" >&2
    return
  fi

  line_count="$(wc -l <"$output" | tr -d '[:space:]')"
  if ((line_count <= max_lines)); then
    cat "$output" >&2
    printf '\nfull check output retained at %s\n' "$output" >&2
    return
  fi

  head_lines=$((max_lines / 2))
  tail_lines=$((max_lines - head_lines))
  omitted=$((line_count - max_lines))

  head -n "$head_lines" "$output" >&2
  printf '\n... omitted %s lines; set CHECK_FAST_MAX_OUTPUT_LINES=0 for full replay ...\n\n' "$omitted" >&2
  tail -n "$tail_lines" "$output" >&2
  printf '\nfull check output retained at %s\n' "$output" >&2
}

run_quiet() {
  local output
  local status

  output="$(mktemp "${TMPDIR:-/tmp}/check-fast.XXXXXX")"
  if echo_commands_enabled; then
    printf ':: %s\n' "$*"
  fi
  if "$@" >"$output" 2>&1; then
    rm -f "$output"
    return 0
  else
    status=$?
    replay_failure_output "$output"
    return "$status"
  fi
}

test_crate() {
  run_quiet cargo test -q -p "$1"
}

test_crates() {
  local crate

  for crate in "$@"; do
    test_crate "$crate"
  done
}

