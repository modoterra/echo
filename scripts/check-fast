add_runtime_test_module_check_for_path() {
  local changed_path="$1"
  local check
  local module
  local module_path
  local description

  while IFS='|' read -r check module module_path description; do
    if [[ "$changed_path" == "$module_path" ]]; then
      add_changed_check "$check"
      return 0
    fi
  done < <(runtime_test_modules)

  return 1
}

run_runtime_test_module_command() {
  local requested="$1"
  local check
  local module
  local module_path
  local description

  while IFS='|' read -r check module module_path description; do
    if [[ "$requested" == "$check" ]]; then
      run_quiet cargo test -q -p echo_runtime "runtime_tests::${module}::" -- --test-threads=1
      return
    fi
  done < <(runtime_test_modules)

  return 1
}

assert_runtime_test_module_routing() {
  local check
  local module
  local module_path
  local description

  while IFS='|' read -r check module module_path description; do
    assert_routing "$description route focused submodule check" "$check" "$module_path"
  done < <(runtime_test_modules)
}

