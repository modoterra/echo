      ;;
    www/*)
      add_changed_check "web"
      ;;
    Cargo.toml|Cargo.lock|crates/*/Cargo.toml)
      add_changed_check "smoke"
      ;;
  esac
}

collect_changed_checks_for_paths() {
  local path
  changed_checks=()
  changed_fixtures=()

  while IFS= read -r path; do
    add_checks_for_changed_path "$path"
  done

  add_changed_fixture_checks
  normalize_changed_checks

  if ((${#changed_checks[@]} == 0)); then
    add_changed_check "smoke"
  fi
}

collect_changed_checks() {
  collect_changed_checks_for_paths < <(changed_files)
}

assert_routing() {
  local name="$1"
  local expected="$2"
  shift 2
  local actual

  actual="$(printf '%s\n' "$@" | {
    collect_changed_checks_for_paths
    printf '%s\n' "${changed_checks[@]}"
  })"
  if [[ "$actual" != "$expected" ]]; then
    printf 'routing test failed: %s\nexpected:\n%s\nactual:\n%s\n' "$name" "$expected" "$actual" >&2
    exit 1
  fi
}

assert_fixture_filter_rejects() {
  local name="$1"
  local filter="$2"
  local output
  local status

  output="$(mktemp "${TMPDIR:-/tmp}/check-fast-script-test.XXXXXX")"
  set +e
  (assert_fixture_filter_matches "$filter" tests/php tests/echo) >"$output" 2>&1
  status=$?
  set -e

  if [[ "$status" == "0" ]]; then
    printf 'fixture validation test failed: %s\nfilter should have been rejected: %s\n' "$name" "$filter" >&2
    rm -f "$output"
    exit 1
  fi

  if ! rg -q "matched no fixture.*__missing_fixture__" "$output"; then
    printf 'fixture validation test failed: %s\nunexpected output:\n' "$name" >&2
    cat "$output" >&2
    rm -f "$output"
    exit 1
  fi

  rm -f "$output"
}

assert_positive_integer() {
  local label="$1"
  local value="$2"

  if [[ ! "$value" =~ ^[0-9]+$ || "$value" == "0" ]]; then
    printf '%s requires a positive integer limit\n' "$label" >&2
    exit 2
  fi
}

assert_command_echo_controls() {
  local default_output
  local quiet_output
  local fixture_output

  default_output="$(CHECK_FAST_ECHO_COMMANDS= run_quiet true)"
  if [[ "$default_output" != ":: true" ]]; then
    printf 'command echo test failed: default trace\nexpected: :: true\nactual: %s\n' "$default_output" >&2
    exit 1
  fi

  quiet_output="$(CHECK_FAST_ECHO_COMMANDS=0 run_quiet true)"
  if [[ -n "$quiet_output" ]]; then
    printf 'command echo test failed: quiet trace should be empty\nactual: %s\n' "$quiet_output" >&2
    exit 1
  fi

  fixture_output="$(CHECK_FAST_ECHO_COMMANDS=0 run_with_optional_fixture "043_strlen_builtin" tests/php -- true)"
  if [[ -n "$fixture_output" ]]; then
    printf 'command echo test failed: quiet fixture trace should be empty\nactual: %s\n' "$fixture_output" >&2
    exit 1
  fi
}

assert_failure_output_is_bounded() {
  local output
  local status

  output="$(mktemp "${TMPDIR:-/tmp}/check-fast-script-test.XXXXXX")"
  set +e
  (
    CHECK_FAST_ECHO_COMMANDS=0 CHECK_FAST_MAX_OUTPUT_LINES=4 \
      run_quiet bash -c 'for line in 1 2 3 4 5 6; do printf "line-%s\n" "$line"; done; exit 7'
  ) >"$output" 2>&1
  status=$?
  set -e

  if [[ "$status" != "7" ]]; then
    printf 'bounded failure output test failed: expected status 7, got %s\n' "$status" >&2
    cat "$output" >&2
    rm -f "$output"
    exit 1
  fi

  if ! rg -q "omitted 2 lines" "$output"; then
    printf 'bounded failure output test failed: missing omission marker\n' >&2
    cat "$output" >&2
    rm -f "$output"
    exit 1
  fi

  if rg -q "line-3|line-4" "$output"; then
    printf 'bounded failure output test failed: omitted middle lines were replayed\n' >&2
    cat "$output" >&2
    rm -f "$output"
    exit 1
  fi

  rm -f "$output"
}

list_changed_checks() {
  local limit="${1:-}"

  if [[ -n "$limit" ]]; then
    assert_positive_integer "changed --list" "$limit"
    printf '%s\n' "${changed_checks[@]:0:limit}"
  else
    printf '%s\n' "${changed_checks[@]}"
  fi
}

assert_changed_list_limit() {
  local actual

  changed_checks=(ast parser semantics)
  actual="$(list_changed_checks 2)"
  if [[ "$actual" != $'ast\nparser' ]]; then
    printf 'changed list limit test failed\nexpected:\nast\nparser\nactual:\n%s\n' "$actual" >&2
    exit 1
  fi

  actual="$(list_changed_checks)"
  if [[ "$actual" != $'ast\nparser\nsemantics' ]]; then
    printf 'changed list full test failed\nexpected:\nast\nparser\nsemantics\nactual:\n%s\n' "$actual" >&2
    exit 1
  fi
}

