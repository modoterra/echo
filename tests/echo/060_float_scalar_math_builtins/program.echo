let $raw = "122.34343The"
let $invalid = "The122.34343"
let $offset = "  -12.5px"

echo "floatval-prefix:[" . gettype(floatval($raw)) . ":" . intval(floatval($raw) * 100000) . "]\n"
echo "floatval-invalid:[" . floatval($invalid) . "]\n"
echo "floatval-offset:[" . intval(floatval($offset) * 10) . "]\n"
echo "floatval-empty:[" . floatval("") . "]\n"
echo "doubleval-exp:[" . doubleval("1e2x") . "]\n"
echo "doubleval-bool:[" . doubleval(true) . "]\n"
echo "pi-scale:[" . gettype(pi()) . ":" . intval(pi() * 1000000) . "]\n"
echo "fmod-positive:[" . gettype(fmod(5.7, 1.3)) . ":" . intval(fmod(5.7, 1.3) * 1000) . "]\n"
echo "fmod-negative:[" . intval(fmod(-5.7, 1.3) * 1000) . "]\n"
echo "fmod-divisor-negative:[" . intval(fmod(5.7, -1.3) * 1000) . "]\n"
echo "fmod-zero:[" . gettype(fmod(5, 0)) . ":" . is_nan(fmod(5, 0)) . "]\n"
echo "fmod-string:[" . intval(fmod("9.5", "2") * 1000) . "]\n"
echo "exists:[" . function_exists("floatval") . function_exists("doubleval") . function_exists("pi") . function_exists("fmod") . "]\n"
