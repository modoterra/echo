from std use net
from std use time
from std use http

let $server = net.listen("127.0.0.1:39185")

let $client = run {
    time.sleep(50)
    let $conn = net.connect("127.0.0.1:39185")
    net.write($conn, "GET /demo HTTP/1.1\r\nHost: localhost\r\n\r\n")
    net.close($conn)
}

let $conn = net.accept($server)
let $request = http.readRequest($conn)

echo $request.path . "\n"

join $client
