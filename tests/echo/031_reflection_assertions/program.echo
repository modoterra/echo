from std use assert
from std use reflect

function greet($name) {
    return "hello " . $name
}

assert.ok(reflect.exists("abs"))
assert.equals(reflect.params("abs"), "int|float $num")
assert.equals(reflect.returnType("abs"), "int|float")
assert.ok(reflect.exists("basename"))
assert.equals(reflect.params("basename"), "string $path, string $suffix")
assert.equals(reflect.returnType("basename"), "string")
assert.ok(reflect.exists("dirname"))
assert.equals(reflect.params("dirname"), "string $path, int $levels")
assert.equals(reflect.returnType("dirname"), "string")
assert.ok(reflect.exists("dechex"))
assert.equals(reflect.params("dechex"), "int $num")
assert.equals(reflect.returnType("dechex"), "string")
assert.ok(reflect.exists("decbin"))
assert.equals(reflect.params("decbin"), "int $num")
assert.equals(reflect.returnType("decbin"), "string")
assert.ok(reflect.exists("decoct"))
assert.equals(reflect.params("decoct"), "int $num")
assert.equals(reflect.returnType("decoct"), "string")
assert.ok(reflect.exists("bindec"))
assert.equals(reflect.params("bindec"), "string $binary_string")
assert.equals(reflect.returnType("bindec"), "int|float")
assert.ok(reflect.exists("hexdec"))
assert.equals(reflect.params("hexdec"), "string $hex_string")
assert.equals(reflect.returnType("hexdec"), "int|float")
assert.ok(reflect.exists("octdec"))
assert.equals(reflect.params("octdec"), "string $octal_string")
assert.equals(reflect.returnType("octdec"), "int|float")
assert.ok(reflect.exists("base_convert"))
assert.equals(reflect.params("base_convert"), "string $num, int $from_base, int $to_base")
assert.equals(reflect.returnType("base_convert"), "string")
assert.ok(reflect.exists("deg2rad"))
assert.equals(reflect.params("deg2rad"), "float $num")
assert.equals(reflect.returnType("deg2rad"), "float")
assert.ok(reflect.exists("rad2deg"))
assert.equals(reflect.params("rad2deg"), "float $num")
assert.equals(reflect.returnType("rad2deg"), "float")
assert.ok(reflect.exists("sin"))
assert.equals(reflect.params("sin"), "float $num")
assert.equals(reflect.returnType("sin"), "float")
assert.ok(reflect.exists("cos"))
assert.equals(reflect.params("cos"), "float $num")
assert.equals(reflect.returnType("cos"), "float")
assert.ok(reflect.exists("tan"))
assert.equals(reflect.params("tan"), "float $num")
assert.equals(reflect.returnType("tan"), "float")
assert.ok(reflect.exists("asin"))
assert.equals(reflect.params("asin"), "float $num")
assert.equals(reflect.returnType("asin"), "float")
assert.ok(reflect.exists("acos"))
assert.equals(reflect.params("acos"), "float $num")
assert.equals(reflect.returnType("acos"), "float")
assert.ok(reflect.exists("atan"))
assert.equals(reflect.params("atan"), "float $num")
assert.equals(reflect.returnType("atan"), "float")
assert.ok(reflect.exists("atan2"))
assert.equals(reflect.params("atan2"), "float $y, float $x")
assert.equals(reflect.returnType("atan2"), "float")
assert.ok(reflect.exists("ceil"))
assert.equals(reflect.params("ceil"), "int|float $num")
assert.equals(reflect.returnType("ceil"), "float")
assert.ok(reflect.exists("floor"))
assert.equals(reflect.params("floor"), "int|float $num")
assert.equals(reflect.returnType("floor"), "float")
assert.ok(reflect.exists("sqrt"))
assert.equals(reflect.params("sqrt"), "float $num")
assert.equals(reflect.returnType("sqrt"), "float")
assert.ok(reflect.exists("hypot"))
assert.equals(reflect.params("hypot"), "float $x, float $y")
assert.equals(reflect.returnType("hypot"), "float")
assert.ok(reflect.exists("pi"))
assert.equals(reflect.params("pi"), "")
assert.equals(reflect.returnType("pi"), "float")
assert.ok(reflect.exists("fmod"))
assert.equals(reflect.params("fmod"), "float $num1, float $num2")
assert.equals(reflect.returnType("fmod"), "float")
assert.ok(reflect.exists("floatval"))
assert.equals(reflect.params("floatval"), "mixed $value")
assert.equals(reflect.returnType("floatval"), "float")
assert.ok(reflect.exists("doubleval"))
assert.equals(reflect.params("doubleval"), "mixed $value")
assert.equals(reflect.returnType("doubleval"), "float")
assert.ok(reflect.exists("escapeshellarg"))
assert.equals(reflect.params("escapeshellarg"), "string $arg")
assert.equals(reflect.returnType("escapeshellarg"), "string")
assert.ok(reflect.exists("escapeshellcmd"))
assert.equals(reflect.params("escapeshellcmd"), "string $command")
assert.equals(reflect.returnType("escapeshellcmd"), "string")
assert.ok(reflect.exists("explode"))
assert.equals(reflect.params("explode"), "string $separator, string $string, int $limit")
assert.equals(reflect.returnType("explode"), "array")
assert.ok(reflect.exists("file_exists"))
assert.equals(reflect.params("file_exists"), "string $filename")
assert.equals(reflect.returnType("file_exists"), "bool")
assert.ok(reflect.exists("is_dir"))
assert.equals(reflect.params("is_dir"), "string $filename")
assert.equals(reflect.returnType("is_dir"), "bool")
assert.ok(reflect.exists("is_file"))
assert.equals(reflect.params("is_file"), "string $filename")
assert.equals(reflect.returnType("is_file"), "bool")
assert.ok(reflect.exists("is_link"))
assert.equals(reflect.params("is_link"), "string $filename")
assert.equals(reflect.returnType("is_link"), "bool")
assert.ok(reflect.exists("strlen"))
assert.equals(reflect.params("strlen"), "string $string")
assert.equals(reflect.returnType("strlen"), "int")
assert.ok(reflect.exists("array_is_list"))
assert.equals(reflect.params("array_is_list"), "array $array")
assert.equals(reflect.returnType("array_is_list"), "bool")
assert.ok(reflect.exists("is_callable"))
assert.equals(reflect.params("is_callable"), "mixed $value")
assert.equals(reflect.returnType("is_callable"), "bool")
assert.ok(reflect.exists("is_float"))
assert.equals(reflect.params("is_float"), "mixed $value")
assert.equals(reflect.returnType("is_float"), "bool")
assert.ok(reflect.exists("is_finite"))
assert.equals(reflect.params("is_finite"), "float $num")
assert.equals(reflect.returnType("is_finite"), "bool")
assert.ok(reflect.exists("is_infinite"))
assert.equals(reflect.params("is_infinite"), "float $num")
assert.equals(reflect.returnType("is_infinite"), "bool")
assert.ok(reflect.exists("is_nan"))
assert.equals(reflect.params("is_nan"), "float $num")
assert.equals(reflect.returnType("is_nan"), "bool")
assert.ok(reflect.exists("is_object"))
assert.equals(reflect.params("is_object"), "mixed $value")
assert.equals(reflect.returnType("is_object"), "bool")
assert.ok(reflect.exists("is_resource"))
assert.equals(reflect.params("is_resource"), "mixed $value")
assert.equals(reflect.returnType("is_resource"), "bool")
assert.ok(reflect.exists("reflect.params"))
assert.equals(reflect.returnType("reflect.params"), "string")
assert.ok(reflect.exists("greet"))
assert.equals(reflect.params("greet"), "$name")
assert.equals(reflect.returnType("greet"), "")
assert.equals(reflect.typeOf(greet("Echo")), "string")
echo "\n"
