from std use reflect

echo "strlen exists:[" . reflect.exists("strlen") . "]\n"
echo "strlen params:[" . reflect.params("strlen") . "]\n"
echo "strlen return:[" . reflect.returnType("strlen") . "]\n"
echo "count params:[" . reflect.params("count") . "]\n"
echo "STRLEN return:[" . reflect.returnType("STRLEN") . "]\n"
echo "time.sleep params:[" . reflect.params("time.sleep") . "]\n"
echo "reflect.params return:[" . reflect.returnType("reflect.params") . "]\n"
echo "missing exists:[" . reflect.exists("definitely_missing_echo_builtin") . "]\n"
echo "missing params:[" . reflect.params("definitely_missing_echo_builtin") . "]\n"
