echo "readable-file:[" . is_readable(__DIR__ . "/data/sample.txt") . "]\n"
echo "readable-missing:[" . is_readable(__DIR__ . "/data/missing.txt") . "]\n"
echo "writable-file:[" . is_writable(__DIR__ . "/data/sample.txt") . "]\n"
echo "executable-script:[" . is_executable(__DIR__ . "/data/run.sh") . "]\n"
echo "executable-file:[" . is_executable(__DIR__ . "/data/sample.txt") . "]\n"
echo "size-file:[" . filesize(__DIR__ . "/data/sample.txt") . "]\n"
echo "realpath-file:[" . basename(realpath(__DIR__ . "/data/../data/sample.txt")) . "]\n"
echo "realpath-missing:[" . realpath(__DIR__ . "/data/missing.txt") . "]\n"
echo "exists:[" . function_exists("is_readable") . function_exists("realpath") . "]\n"
