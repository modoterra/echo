type Request = {
    path: string
}

type User = {
    const id: int
    email: string
}

fn responseBody($request, list<User> $users): string {
    return "Hello from Echo at " . $request.path . "\nUsers seen: " . count($users) . "\n"
}

let $request = Request {
    path: "/demo"
}
let $users: list<User> = {}
$users.push({
    id: 1
    email: "first@example.test"
}: User)

echo responseBody($request, $users)
